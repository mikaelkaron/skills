{
  "name": "@mikaelkaron/skills",
  "version": "0.1.1",
  "bin": {
    "mks": "bin/run.js"
  },
  "workspaces": [
    "packages/*"
  ],
  "files": [
    "bin"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "test": "node --experimental-strip-types --test 'packages/*/test/**/*.test.ts'",
    "test:types": "tsc -b tsconfig.test.json --noEmit",
    "lint": "oxlint .",
    "format": "oxfmt ."
  },
  "dependencies": {
    "@mikaelkaron/skills-cli": "^0.1.1"
  },
  "devDependencies": {
    "oxfmt": "^0.51.0",
    "oxlint": "^1.66.0"
  },
  "engines": {
    "node": ">=22.18"
  }
}
