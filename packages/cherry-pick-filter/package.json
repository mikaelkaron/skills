{
  "name": "@mikaelkaron/skills-cherry-pick-filter",
  "version": "0.2.1",
  "bin": {
    "mks-cherry-pick-filter": "bin/run.js"
  },
  "files": [
    "bin",
    "dist",
    "oclif.manifest.json"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "pretest": "tsc -b test/tsconfig.json",
    "test": "node --test 'dist/test/**/*.test.js'",
    "test:types": "tsc -b test/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@oclif/core": "^4"
  },
  "devDependencies": {
    "@oclif/test": "^4.1.18",
    "@types/node": "^22",
    "typescript": "^5"
  },
  "oclif": {
    "bin": "mks-cherry-pick-filter",
    "commands": {
      "globPatterns": [
        "**/*.js"
      ],
      "strategy": "pattern",
      "target": "./dist/commands"
    },
    "id": "cherry-pick-filter"
  },
  "engines": {
    "node": ">=22.18"
  },
  "tessl": {
    "tile": "mikaelkaron/cherry-pick-filter",
    "version": "0.1.6"
  }
}
