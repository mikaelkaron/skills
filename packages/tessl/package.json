{
  "name": "@mikaelkaron/skills-tessl",
  "version": "0.2.1",
  "bin": {
    "mks-tessl": "bin/run.js"
  },
  "files": [
    "bin",
    "dist",
    "oclif.manifest.json"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "pretest": "tsc -b test/tsconfig.json",
    "test": "node --test 'dist/test/**/*.test.js'",
    "test:types": "tsc -b test/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@oclif/core": "^4"
  },
  "devDependencies": {
    "@oclif/test": "^4.1.18",
    "@types/node": "^22",
    "typescript": "^5"
  },
  "oclif": {
    "bin": "mks-tessl",
    "commands": {
      "globPatterns": [
        "**/*.js"
      ],
      "strategy": "pattern",
      "target": "./dist/commands"
    },
    "id": "tessl"
  },
  "engines": {
    "node": ">=22.18"
  },
  "tessl": {
    "tile": "mikaelkaron/tessl",
    "version": "0.1.0"
  }
}
