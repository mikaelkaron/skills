{
  "name": "@mikaelkaron/skills-tessl",
  "version": "2.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/mikaelkaron/skills",
    "directory": "packages/tessl"
  },
  "bin": {
    "mks-tessl": "bin/run.js"
  },
  "files": [
    "bin",
    "dist",
    "oclif.manifest.json"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run build && oclif manifest .",
    "postpublish": "rm -f oclif.manifest.json",
    "pretest": "npm run build",
    "test": "node --experimental-strip-types --test 'test/**/*.test.ts'",
    "test:coverage": "node --experimental-strip-types --experimental-test-coverage --test 'test/**/*.test.ts'",
    "test:types": "tsc -p test/tsconfig.json"
  },
  "dependencies": {
    "@oclif/core": "^4",
    "which": "^7.0.0"
  },
  "devDependencies": {
    "@oclif/test": "^4.1.18",
    "@types/node": "^22",
    "@types/which": "^3.0.4",
    "oclif": "^4",
    "typescript": "^5"
  },
  "oclif": {
    "bin": "mks-tessl",
    "commands": {
      "globPatterns": [
        "**/*.js"
      ],
      "strategy": "pattern",
      "target": "./dist/commands"
    },
    "id": "tessl",
    "topics": {
      "tessl": {
        "description": "Manage tessl skill tiles for installed plugins."
      }
    }
  },
  "engines": {
    "node": ">=22.18"
  },
  "tessl": {
    "tile": "mikaelkaron/tessl",
    "version": "0.4.0"
  }
}
