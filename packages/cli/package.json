{
  "name": "@mikaelkaron/skills-cli",
  "version": "0.6.0",
  "bin": {
    "mks": "bin/run.js"
  },
  "files": [
    "bin",
    "oclif.manifest.json"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepublishOnly": "oclif manifest .",
    "postpublish": "rm -f oclif.manifest.json",
    "test": "node --experimental-strip-types --test 'test/**/*.test.ts'",
    "test:coverage": "node --experimental-strip-types --experimental-test-coverage --test 'test/**/*.test.ts'",
    "test:types": "tsc -p test/tsconfig.json"
  },
  "dependencies": {
    "@oclif/core": "^4",
    "@oclif/plugin-plugins": "^5"
  },
  "devDependencies": {
    "@oclif/test": "^4.1.18",
    "@types/node": "^22",
    "oclif": "^4",
    "typescript": "^5"
  },
  "oclif": {
    "bin": "mks",
    "dirname": "mikaelkaron/skills",
    "id": "cli",
    "pluginPrefix": "skills",
    "plugins": [
      "@oclif/plugin-plugins"
    ],
    "scope": "mikaelkaron"
  },
  "engines": {
    "node": ">=22.18"
  },
  "tessl": {
    "tile": "mikaelkaron/cli",
    "version": "0.3.0"
  }
}
