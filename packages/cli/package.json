{
  "name": "@mikaelkaron/skills-cli",
  "version": "0.2.0",
  "bin": {
    "mks": "bin/run.js"
  },
  "files": [
    "bin"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "pretest": "tsc -b test/tsconfig.json",
    "test": "node --test 'dist/test/**/*.test.js'",
    "test:types": "tsc -b test/tsconfig.json --noEmit"
  },
  "dependencies": {
    "@oclif/core": "^4",
    "@oclif/plugin-plugins": "^5"
  },
  "devDependencies": {
    "@oclif/test": "^4.1.18",
    "@types/node": "^22",
    "typescript": "^5"
  },
  "oclif": {
    "bin": "mks",
    "dirname": "mikaelkaron/skills",
    "pluginPrefix": "skills",
    "plugins": [
      "@oclif/plugin-plugins"
    ],
    "scope": "mikaelkaron"
  },
  "engines": {
    "node": ">=22.18"
  }
}
